APP_NAME="Officina Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=officina_hub
DB_USERNAME=root
DB_PASSWORD=

# Sessioni — 8 ore = turno di lavoro; SESSION_SECURE_COOKIE=false solo per sviluppo HTTP
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache: file è il driver di default (zero dipendenze).
# Per invalidazione con tag (Cache::tags) usare redis.
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@officinahub.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Step 9 — Sicurezza & Backup ─────────────────────────────────────────────

# Backup Spatie — password opzionale per cifrare lo ZIP (lasciare vuoto per nessuna cifratura)
BACKUP_PASSWORD=
# Email destinatario notifiche backup (fallback: MAIL_FROM_ADDRESS)
BACKUP_NOTIFY_EMAIL=

# Audit log attività
ACTIVITY_LOGGER_ENABLED=true

# ─── Step 9 — SDI diretto (NON abilitare senza accreditamento AdE) ───────────
# Vedere docs/sdi-diretto.md per i passi necessari all'attivazione
SDI_ABILITATO=false
SDI_CANALE=sftp
SDI_SFTP_HOST=
SDI_SFTP_PORT=22
SDI_SFTP_USERNAME=
SDI_SFTP_PRIVATE_KEY_PATH=
SDI_SFTP_DIR_IN=/ricezione
SDI_SFTP_DIR_OUT=/trasmissione
SDI_CERT_PATH=
SDI_CERT_PASSWORD=

# Tech Board (monitor a parete) — solo su rete locale officina, espone targhe e nomi
# Generare con: php artisan tinker --execute="echo Str::random(64);"
TECHBOARD_TOKEN=
